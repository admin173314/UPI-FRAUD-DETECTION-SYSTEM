class UPIFraudDetector:
    """
    Real-time UPI Fraud Detection System.
    
    This class provides a complete pipeline for detecting fraudulent
    UPI transactions in real-time using trained ML models.
    """
    
    def __init__(self, model, scaler, feature_columns, threshold=0.8):
        """
        Initialize the fraud detector.
        
        Parameters:
        -----------
        model : sklearn estimator
            Trained machine learning model
        scaler : StandardScaler
            Fitted feature scaler
        feature_columns : list
            List of feature column names
        threshold : float
            Probability threshold for fraud detection (default: 0.8)
        """
        self.model = model
        self.scaler = scaler
        self.feature_columns = feature_columns
        self.threshold = threshold
        self.alert_count = 0
        self.blocked_count = 0
        self.transaction_log = []
    
    def preprocess_transaction(self, transaction):
        """Preprocess a single transaction for prediction."""
        df = pd.DataFrame([transaction])
        
        # Apply feature engineering
        df['is_night'] = ((df['hour'] >= 0) & (df['hour'] <= 5)).astype(int)
        df['amount_log'] = np.log1p(df['amount'])
        df['is_high_amount'] = (df['amount'] > 50000).astype(int)
        df['amount_deviation'] = abs(df['amount'] - 500)
        df['amount_zscore'] = 0
        df['distance_from_center'] = np.sqrt(
            (df['latitude'] - 20.59)**2 + (df['longitude'] - 78.96)**2
        )
        df['is_high_frequency'] = (df['txn_frequency_24h'] > 10).astype(int)
        
        device_risk = {'Android': 1, 'iOS': 1, 'Web': 2, 'USSD': 3}
        df['device_risk'] = df['device_type'].map(device_risk).fillna(1)
        
        merchant_risk = {m: 1 for m in df['merchant'].unique()}
        merchant_risk['unknown'] = 3
        df['merchant_risk'] = df['merchant'].map(merchant_risk).fillna(1)
        
        return df[self.feature_columns]
    
    def predict(self, transaction):
        """Predict if a transaction is fraudulent."""
        X = self.preprocess_transaction(transaction)
        X_scaled = self.scaler.transform(X)
        probability = self.model.predict_proba(X_scaled)[0, 1]
        prediction = 1 if probability >= self.threshold else 0
        return prediction, probability
    
    def process_transaction(self, transaction):
        """Process a transaction and generate alert if fraud detected."""
        prediction, probability = self.predict(transaction)
        
        result = {
            'transaction_id': transaction['transaction_id'],
            'amount': transaction['amount'],
            'prediction': 'FRAUD' if prediction == 1 else 'LEGITIMATE',
            'confidence': probability,
            'action': None,
            'alert': False,
            'timestamp': pd.Timestamp.now()
        }
        
        if prediction == 1:
            self.alert_count += 1
            result['alert'] = True
            
            if probability > 0.95:
                result['action'] = 'BLOCKED - High Risk'
                self.blocked_count += 1
            elif probability > 0.85:
                result['action'] = 'FLAGGED - Additional Verification Required'
            else:
                result['action'] = 'FLAGGED - Review Recommended'
        else:
            result['action'] = 'APPROVED'
        
        self.transaction_log.append(result)
        return result
    
    def generate_alert_message(self, result):
        """Generate formatted alert message."""
        if not result['alert']:
            return None
        
        msg = f"""
============================================================
                    FRAUD ALERT
============================================================
Transaction ID: {result['transaction_id']}
Amount: Rs. {result['amount']:.2f}
Risk Score: {result['confidence']*100:.1f}%
Status: {result['prediction']}
Action: {result['action']}
============================================================
        """
        return msg
    
    def get_summary(self):
        """Get system summary statistics."""
        total = len(self.transaction_log)
        return {
            'total_processed': total,
            'alerts_generated': self.alert_count,
            'transactions_blocked': self.blocked_count,
            'fraud_rate': (self.alert_count / total * 100) if total > 0 else 0
        }
    
    def save_model(self, filepath='upi_fraud_model.pkl'):
        """Save the trained model and scaler."""
        joblib.dump({'model': self.model, 'scaler': self.scaler, 
                     'features': self.feature_columns}, filepath)
        print(f"Model saved to {filepath}")
    
    @classmethod
    def load_model(cls, filepath='upi_fraud_model.pkl', threshold=0.8):
        """Load a saved model and create detector instance."""
        data = joblib.load(filepath)
        return cls(data['model'], data['scaler'], data['features'], threshold)


