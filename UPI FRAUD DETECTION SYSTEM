def train_and_evaluate_models(X_train, X_test, y_train, y_test):
    """
    Train multiple ML models and evaluate their performance.
    
    Parameters:
    -----------
    X_train, X_test : array-like
        Training and test feature matrices
    y_train, y_test : array-like
        Training and test labels
    
    Returns:
    --------
    pd.DataFrame
        Results comparison table
    dict
        Trained models dictionary
    """
    models = {
        'Logistic Regression': LogisticRegression(random_state=42, max_iter=1000, class_weight='balanced'),
        'Decision Tree': DecisionTreeClassifier(random_state=42, class_weight='balanced'),
        'Random Forest': RandomForestClassifier(n_estimators=100, random_state=42, class_weight='balanced', n_jobs=-1),
        'SVM': SVC(random_state=42, class_weight='balanced', probability=True),
        'KNN': KNeighborsClassifier(n_neighbors=5),
        'Isolation Forest': IsolationForest(random_state=42, contamination=0.05, n_jobs=-1)
    }
    
    results = []
    trained_models = {}
    
    for name, model in models.items():
        print(f"\\nTraining {name}...")
        
        if name == 'Isolation Forest':
            model.fit(X_train)
            y_pred = model.predict(X_test)
            y_pred = np.where(y_pred == -1, 1, 0)
            y_prob = np.zeros(len(y_test))
        else:
            model.fit(X_train, y_train)
            y_pred = model.predict(X_test)
            y_prob = model.predict_proba(X_test)[:, 1]
        
        accuracy = accuracy_score(y_test, y_pred)
        precision = precision_score(y_test, y_pred, zero_division=0)
        recall = recall_score(y_test, y_pred, zero_division=0)
        f1 = f1_score(y_test, y_pred, zero_division=0)
        auc = roc_auc_score(y_test, y_prob) if name != 'Isolation Forest' else 0.5
        
        results.append({
            'Model': name,
            'Accuracy': accuracy,
            'Precision': precision,
            'Recall': recall,
            'F1 Score': f1,
            'AUC-ROC': auc
        })
        
        trained_models[name] = model
        print(f"  Accuracy: {accuracy:.4f} | F1: {f1:.4f} | AUC: {auc:.4f}")
    
    results_df = pd.DataFrame(results)
    return results_df, trained_models


def train_gradient_boosting(X_train, y_train):
    """Train Gradient Boosting (or XGBoost if available) model."""
    try:
        import xgboost as xgb
        model = xgb.XGBClassifier(
            n_estimators=200, max_depth=6, learning_rate=0.1,
            subsample=0.8, colsample_bytree=0.8, random_state=42,
            scale_pos_weight=19, eval_metric='logloss'
        )
        model_name = "XGBoost"
    except ImportError:
        model = GradientBoostingClassifier(
            n_estimators=200, max_depth=6, learning_rate=0.1, random_state=42
        )
        model_name = "Gradient Boosting"
    
    print(f"\\nTraining {model_name}...")
    model.fit(X_train, y_train)
    print(f"  {model_name} trained successfully!")
    return model, model_name


def evaluate_model(model, X_test, y_test, model_name="Model"):
    """Evaluate a trained model and print detailed metrics."""
    y_pred = model.predict(X_test)
    y_prob = model.predict_proba(X_test)[:, 1]
    
    accuracy = accuracy_score(y_test, y_pred)
    precision = precision_score(y_test, y_pred)
    recall = recall_score(y_test, y_pred)
    f1 = f1_score(y_test, y_pred)
    auc = roc_auc_score(y_test, y_prob)
    
    cm = confusion_matrix(y_test, y_pred)
    tn, fp, fn, tp = cm.ravel()
    fpr = fp / (fp + tn)
    fnr = fn / (fn + tp)
    
    print(f"\\n{'='*60}")
    print(f"{model_name} EVALUATION RESULTS")
    print(f"{'='*60}")
    print(f"Accuracy:  {accuracy:.4f} ({accuracy*100:.2f}%)")
    print(f"Precision: {precision:.4f} ({precision*100:.2f}%)")
    print(f"Recall:    {recall:.4f} ({recall*100:.2f}%)")
    print(f"F1 Score:  {f1:.4f} ({f1*100:.2f}%)")
    print(f"AUC-ROC:   {auc:.4f}")
    print(f"\\nConfusion Matrix:")
    print(f"  TP={tp}, FP={fp}, FN={fn}, TN={tn}")
    print(f"  FPR: {fpr*100:.2f}% | FNR: {fnr*100:.2f}%")
    
    return {
        'accuracy': accuracy, 'precision': precision, 'recall': recall,
        'f1': f1, 'auc': auc, 'cm': cm, 'fpr': fpr, 'fnr': fnr
    }


